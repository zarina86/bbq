<% button_delete = button_to  I18n.t('button.delete'),
                                 event_photo_path(photo.event, photo),
                                 class: "btn btn-link",
                                 method: :delete,
                                 form: { data: { turbo_confirm: I18n.t('photos.photo.destroy_confirm') } }%>
<% title = "Добавил #{photo.user.name}" %>
<% link = url_for(photo.photo.variant(resize_to_fill: [600, 400])) %>

<% if current_user_can_edit?(photo) %>
  <% title << "#{button_delete}"%>
<% end %>

<%= link_to image_tag(photo.photo.variant(resize_to_fill: [150, 150])), url_for(photo.photo),  class: "lightboxed", rel: "group", data: { caption: title } %>
